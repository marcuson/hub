{
	"type": "module",
	"scripts": {
		"build": "eleventy",
		"build:dev": "cross-env ELEVENTY_ENV=dev eleventy",
		"clean": "rimraf _site .wrangler",
		"dev": "pnpm run \"/^dev:.*/\"",
		"dev:watch": "cross-env ELEVENTY_ENV=dev eleventy --watch",
		"dev:cfserve": "wrangler pages dev --ip=0.0.0.0 _site"
	},
	"devDependencies": {
		"11ty.ts": "^0.0.7",
		"@11ty/eleventy": "^3.1.6",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"cross-env": "^10.1.0",
		"cssnano": "^8.0.2",
		"normalize.css": "^8.0.1",
		"postcss": "^8.5.19",
		"postcss-nested": "^7.0.2",
		"prismjs": "^1.30.0",
		"rimraf": "^6.1.3",
		"wrangler": "^4.110.0"
	}
}